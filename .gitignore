# APM dependency cache (resolved from apm.lock.yaml on `apm install`).
# The lockfile IS committed; the materialized modules are not.
apm_modules/

# Harness-deploy outputs. This repo is an APM *producer*: primitives are
# authored in .apm/ and dependencies are pinned with `apm lock` (which does
# NOT deploy). `apm install` would materialize primitives into the harness
# dirs below — never commit those here (they collide with the repo's own
# .apm/ source and the index/validate tooling).
.agents/
.github/agents/
.github/instructions/